# Langfuse 环境配置示例
# 复制此文件为 .env.langfuse 并根据需要修改

# ==========================================================================
# Langfuse Server 配置 (用于本地部署连接)
# ==========================================================================
LANGFUSE_HOST=http://localhost:3000

# ==========================================================================
# Langfuse API Keys (首次部署后从 Web UI 创建)
# ==========================================================================
# 1. 访问 http://localhost:3000
# 2. 创建项目和 API Keys
# 3. 将生成的密钥填入下方
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxx

# ==========================================================================
# 安全密钥 (用于 Docker Compose 部署)
# ==========================================================================
# 生产环境请使用强随机密钥（至少 32 字符）
LANGFUSE_NEXTAUTH_SECRET=changeme-secret-min-32-chars-long-for-local-dev
LANGFUSE_SALT=changeme-salt-min-32-chars-long-for-local-dev
LANGFUSE_ENCRYPTION_KEY=changeme-encryption-key-32-bytes-for-local-dev

# ==========================================================================
# SDK 配置
# ==========================================================================
# 应用版本标识
LANGFUSE_RELEASE=local-dev

# 调试模式 (开发时启用)
LANGFUSE_DEBUG=false

# 采样率 (1.0 = 全量记录, 0.1 = 10% 采样)
LANGFUSE_SAMPLE_RATE=1.0

# ==========================================================================
# 连接测试
# ==========================================================================
# 测试连接是否正常:
#   curl http://localhost:3000/api/health
